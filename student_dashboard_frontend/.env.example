# Build-time base URL for the FastAPI backend.
# Needed because next.config.ts currently uses output: "export" (static export),
# so runtime env vars are not available.
#
# Example:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_API_BASE_URL=https://your-backend.example.com
NEXT_PUBLIC_API_BASE_URL=

# Optional: control mock behavior.
# - off (default): always call backend; throw on errors (no silent mock fallback)
# - fallback: call backend; if it fails, fall back to mock data (useful for offline demos)
# - on: always use mock data (never call backend)
NEXT_PUBLIC_API_MOCK_MODE=off
